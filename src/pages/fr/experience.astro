---
import BaseLayout from '../../layouts/BaseLayout.astro';

const education = [
  {
    institution: "Université de Toulouse (IRIT, IMT, CLLE)",
    degree: "Doctorat en Intelligence Artificielle",
    period: "Nov. 2025 – Nov. 2028",
    location: "Toulouse, France",
    note: "Sujet : Reconnaissance de texte manuscrit dans les manuscrits scientifiques arabes médiévaux et développement d'un LLM dédié.",
  },
  {
    institution: "École Nationale Supérieure d'Arts et Métiers",
    degree: "Diplôme d'Ingénieur d'État — IA & Génie Informatique",
    period: "Sep. 2022 – Sep. 2025",
    location: "Casablanca, Maroc",
    note: "Accès sélectif sur moyenne. Diplômé avec les Félicitations du jury.",
  },
  {
    institution: "Lycée Euclide",
    degree: "Baccalauréat en Sciences Mathématiques (option française)",
    period: "Sep. 2019 – Jul. 2020",
    location: "Mohammedia, Maroc",
    note: "Mention Très Bien.",
  },
];

const experience = [
  {
    role: "Stagiaire Recherche — IA & Imagerie Médicale",
    org: "Institut de Recherche en Informatique de Toulouse (IRIT)",
    period: "Mar. 2025 – Sep. 2025",
    location: "Toulouse, France",
    objective: "Segmentation d'images médicales par apprentissage few-shot.",
    bullets: [
      "Revue de l'état de l'art des algorithmes de segmentation à données limitées et d'apprentissage few-shot.",
      "Traitement d'images IRM et TDM, compréhension de leurs spécificités et formats.",
      "Développement d'un modèle de segmentation basé sur l'architecture U-Net en configuration few-shot.",
    ],
  },
  {
    role: "Développeur Bénévole Vision par Ordinateur",
    org: "Association Youth For Challenge",
    period: "Aoû. 2024 – Déc. 2024",
    location: "Casablanca, Maroc",
    objective: "Plateforme intelligente de traduction temps réel langue des signes vers texte pour personnes sourdes et muettes.",
    bullets: [
      "Revue de l'état de l'art des méthodes de détection et segmentation de mains.",
      "Développement d'un algorithme CNN de reconnaissance de gestes.",
      "Création d'une interface et déploiement avec Flask et OpenCV.",
    ],
  },
  {
    role: "Stagiaire Vision par Ordinateur",
    org: "SYGMA.AI (InsurTech)",
    period: "Avr. 2024 – Jun. 2024",
    location: "Casablanca, Maroc",
    objective: "Solution intelligente de segmentation des zones endommagées de véhicules pour l'évaluation automatique des assurances.",
    bullets: [
      "Collecte et traitement d'images automobiles avec Python, Selenium et Scrapy.",
      "Implémentation d'un CNN de classification de véhicules endommagés avec PyTorch.",
      "Développement d'un algorithme de vérification de plaque d'immatriculation combinant CNN et OCR.",
    ],
  },
  {
    role: "Stagiaire IA & Traitement d'Images",
    org: "Lesieur Cristal",
    period: "Jul. 2023",
    location: "Casablanca, Maroc",
    objective: "Détection d'équipements de protection individuelle (EPI) à partir de vidéo pour réduire les risques opérationnels en milieu industriel.",
    bullets: [
      "Constitution d'un jeu de données structuré contenant diverses classes d'EPI.",
      "Conception d'un algorithme de détection et reconnaissance d'EPI basé sur CNN.",
    ],
  },
];

const skills = {
  "Data Science": ["Python", "Pandas", "NumPy", "Matplotlib", "Seaborn", "Plotly", "Selenium", "Scrapy"],
  "IA / Outils ML": ["Scikit-learn", "Keras", "TensorFlow", "PyTorch", "MONAI", "SimpleITK", "OpenCV", "HF Transformers", "spaCy", "NLTK", "pyarabic"],
  "Architectures": ["CNN", "U-Net", "RNN", "LSTM", "Transformers", "ViT", "VLM"],
  "Langages": ["Python", "JavaScript", "SQL", "Bash"],
};

const certs = [
  { name: "Data Scientist Associate (90h)", issuer: "DataCamp", date: "Nov. 2024" },
  { name: "Advanced Learning Algorithms (34h)", issuer: "DeepLearning.AI", date: "Avr. 2023" },
  { name: "Supervised Machine Learning: Regression & Classification (33h)", issuer: "DeepLearning.AI", date: "Mar. 2023" },
  { name: "Machine Learning for Time Series Data in Python (4h)", issuer: "DataCamp", date: "Nov. 2024" },
];
---

<BaseLayout title="Expérience" description="Formation, expérience professionnelle et compétences techniques d'Ismail El Jamiy.">
  <div class="page-container">

    <header class="page-header">
      <div class="page-header-row">
        <div>
          <div class="page-eyebrow">CV &amp; Parcours</div>
          <h1 class="page-title">Expérience</h1>
          <div class="page-rule-short" aria-hidden="true"></div>
        </div>
        <a href="/Resume.pdf" target="_blank" rel="noopener" class="cv-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Télécharger le CV
        </a>
      </div>
    </header>

    <section class="cv-section">
      <h2 class="section-title">Formation</h2>
      <div class="timeline">
        {education.map(ed => (
          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-body">
              <div class="tl-header">
                <span class="tl-role">{ed.degree}</span>
                <span class="tl-period">{ed.period}</span>
              </div>
              <span class="tl-org">{ed.institution}</span>
              <span class="tl-location">{ed.location}</span>
              {ed.note && <p class="tl-note">{ed.note}</p>}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="cv-section">
      <h2 class="section-title">Expérience professionnelle</h2>
      <div class="timeline">
        {experience.map(exp => (
          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-body">
              <div class="tl-header">
                <span class="tl-role">{exp.role}</span>
                <span class="tl-period">{exp.period}</span>
              </div>
              <span class="tl-org">{exp.org}</span>
              <span class="tl-location">{exp.location}</span>
              {exp.objective && <p class="tl-objective"><strong>Objectif :</strong> {exp.objective}</p>}
              <ul class="tl-bullets">
                {exp.bullets.map(b => <li>{b}</li>)}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="cv-section">
      <h2 class="section-title">Compétences techniques</h2>
      <div class="skills-grid">
        {Object.entries(skills).map(([cat, items]) => (
          <div class="skill-group">
            <h3 class="skill-cat">{cat}</h3>
            <div class="skill-tags">
              {items.map(s => <span class="tag">{s}</span>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="cv-section">
      <h2 class="section-title">Certifications</h2>
      <ul class="cert-list">
        {certs.map(c => (
          <li class="cert-item card">
            <span class="cert-name">{c.name}</span>
            <span class="cert-meta">{c.issuer} · {c.date}</span>
          </li>
        ))}
      </ul>
    </section>

  </div>
</BaseLayout>

<style>
  .page-container { max-width: 820px; margin: 0 auto; padding: 4rem 1.5rem 5rem; }
  .page-header { margin-bottom: 3rem; }
  .page-header-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .page-title { font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 600; color: var(--fg); margin-bottom: 0.75rem; }
  .cv-btn { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-sans); font-size: 0.85rem; font-weight: 600; color: var(--accent); border: 1.5px solid var(--accent); border-radius: 0.375rem; padding: 0.5rem 1rem; text-decoration: none; white-space: nowrap; transition: background 0.2s, color 0.2s; margin-top: 0.5rem; }
  .cv-btn:hover { background: var(--accent); color: white; }
  .cv-section { margin-bottom: 3.5rem; }
  .section-title { font-family: var(--font-serif); font-size: 1.5rem; font-weight: 600; color: var(--color-olive); margin-bottom: 1.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border); }
  .timeline { display: flex; flex-direction: column; gap: 0; border-left: 2px solid var(--border); padding-left: 1.5rem; margin-left: 0.5rem; }
  .timeline-item { position: relative; padding-bottom: 2rem; }
  .timeline-dot { position: absolute; left: -1.75rem; top: 0.3rem; width: 14px; height: 14px; border-radius: 50%; background: linear-gradient(135deg, var(--color-olive), var(--color-terracotta)); border: 2px solid var(--bg); box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-olive) 30%, transparent); }
  .tl-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.2rem; }
  .tl-role { font-family: var(--font-serif); font-size: 1.05rem; font-weight: 600; color: var(--fg); }
  .tl-period { font-family: var(--font-sans); font-size: 0.7rem; font-weight: 500; color: var(--color-olive); background: color-mix(in srgb, var(--color-olive) 8%, transparent); border: 1px solid color-mix(in srgb, var(--color-olive) 22%, transparent); border-radius: 9999px; padding: 0.15rem 0.65rem; white-space: nowrap; }
  .tl-org { display: block; font-family: var(--font-sans); font-size: 0.875rem; font-weight: 600; color: var(--accent); }
  .tl-location { display: block; font-family: var(--font-sans); font-size: 0.8rem; color: var(--fg-muted); margin-bottom: 0.5rem; }
  .tl-objective { font-family: var(--font-sans); font-size: 0.875rem; color: var(--fg-muted); margin: 0.5rem 0; }
  .tl-note { font-family: var(--font-sans); font-size: 0.85rem; color: var(--fg-muted); font-style: italic; margin: 0.4rem 0 0; }
  .tl-bullets { list-style: none; padding: 0; margin: 0; }
  .tl-bullets li { font-family: var(--font-sans); font-size: 0.875rem; color: var(--fg-muted); padding-left: 1rem; position: relative; margin-bottom: 0.3em; }
  .tl-bullets li::before { content: "–"; position: absolute; left: 0; color: var(--color-terracotta); }
  .skills-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.25rem; }
  .skill-group { padding: 1.25rem; background: var(--bg-panel); border: 1px solid var(--border); border-radius: 0.5rem; }
  .skill-cat { font-family: var(--font-sans); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--fg-muted); margin-bottom: 0.75rem; }
  .skill-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .tag { font-family: var(--font-mono); font-size: 0.72rem; padding: 0.15rem 0.5rem; background: color-mix(in srgb, var(--color-olive) 10%, transparent); color: var(--color-olive); border-radius: 4px; }
  .cert-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .cert-item { display: flex; flex-direction: column; gap: 0.25rem; padding: 1rem 1.25rem; }
  .cert-name { font-family: var(--font-serif); font-size: 0.975rem; font-weight: 600; color: var(--fg); }
  .cert-meta { font-family: var(--font-sans); font-size: 0.8rem; color: var(--fg-muted); }
</style>
