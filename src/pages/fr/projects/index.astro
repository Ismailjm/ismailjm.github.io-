---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const projects = (await getCollection('projects'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const techIcons: Record<string, string> = {
  "Python":          "python",
  "PyTorch":         "pytorch",
  "TensorFlow":      "tensorflow",
  "Keras":           "keras",
  "Scikit-learn":    "scikitlearn",
  "OpenCV":          "opencv",
  "Pandas":          "pandas",
  "NumPy":           "numpy",
  "Matplotlib":      "matplotlib",
  "Plotly":          "plotly",
  "Selenium":        "selenium",
  "YOLOv8":          "ultralytics",
  "Ultralytics":     "ultralytics",
  "Streamlit":       "streamlit",
  "Flask":           "flask",
  "LangChain":       "langchain",
  "OpenAI":          "openai",
  "Ollama":          "ollama",
  "HF Transformers": "huggingface",
  "JavaScript":      "javascript",
  "Bash":            "gnubash",
};
---

<BaseLayout title="Projets" description="Projets d'Ismail El Jamiy en vision par ordinateur, NLP et IA.">
  <div class="page-container">

    <header class="page-header">
      <div class="page-eyebrow">Travaux sélectionnés</div>
      <h1 class="page-title">Projets</h1>
      <div class="page-rule-short" aria-hidden="true"></div>
    </header>

    <div class="projects-grid">
      {projects.map(project => (
        <div class="project-card card" data-href={`/fr/projects/${project.id}`} role="article">
          {project.data.cover && (
            <div class="project-cover">
              <Image src={project.data.cover} alt={project.data.title}
                widths={[400, 800]} sizes="(max-width: 700px) 90vw, 400px" loading="lazy" />
            </div>
          )}
          <div class="project-body">
            <div class="project-card-top">
              <h2 class="project-title">{project.data.title}</h2>
              <span class="project-date">{project.data.date.slice(0, 7)}</span>
            </div>
            <p class="project-summary">{project.data.summary}</p>
            <div class="project-stack">
              {project.data.stack.slice(0, 6).map((tag: string) => {
                const icon = techIcons[tag];
                return (
                  <span class={`stack-tag${icon ? " has-icon" : ""}`}>
                    {icon && (
                      <img
                        src={`https://cdn.simpleicons.org/${icon}`}
                        width="11" height="11"
                        alt="" aria-hidden="true"
                        class="stack-icon"
                        onerror="this.closest('.has-icon')?.classList.remove('has-icon');this.remove()"
                      />
                    )}
                    {tag}
                  </span>
                );
              })}
            </div>
            <div class="project-links">
              {project.data.links?.github && (
                <a href={project.data.links.github} target="_blank" rel="noopener"
                   class="project-link" onclick="event.stopPropagation()">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                  </svg>
                  GitHub
                </a>
              )}
              <a href={`/fr/projects/${project.id}`} class="project-link-read" onclick="event.stopPropagation()">
                En savoir plus →
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLElement>('.project-card[data-href]').forEach(card => {
    card.addEventListener('click', (e) => {
      if (!(e.target as Element).closest('a')) {
        window.location.href = card.dataset.href!;
      }
    });
  });
</script>

<style>
  .page-container {
    max-width: 960px;
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem;
  }

  .page-header { margin-bottom: 2.5rem; }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 0.75rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.75rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    cursor: pointer;
    overflow: hidden;
  }

  .project-cover {
    width: 100%;
    height: 200px;
    overflow: hidden;
    background: var(--bg-panel);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }

  .project-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .project-card:hover .project-cover img {
    transform: scale(1.04);
  }

  .project-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
    flex: 1;
  }

  .project-card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .project-title {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--fg);
    line-height: 1.35;
  }

  .project-date {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: var(--fg-muted);
    white-space: nowrap;
    padding-top: 0.15rem;
    flex-shrink: 0;
  }

  .project-summary {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--fg-muted);
    line-height: 1.6;
    flex: 1;
    margin: 0;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .stack-tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.2rem 0.5rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 0.2rem;
    color: var(--fg-muted);
  }

  .stack-tag.has-icon {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .stack-icon {
    display: block;
    flex-shrink: 0;
    width: 11px;
    height: 11px;
    object-fit: contain;
  }

  [data-theme="dark"] .stack-icon { filter: brightness(1.2); }

  .project-links {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--fg-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .project-link:hover { color: var(--accent); }

  .project-link-read {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    margin-left: auto;
    transition: opacity 0.15s;
  }
  .project-link-read:hover { opacity: 0.75; }
</style>
