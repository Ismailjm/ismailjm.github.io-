  {
    label: "Google Scholar",
    value: "Ismail El Jamiy",
    href: "https://scholar.google.com/citations?user=QDB_Lh4AAAAJ&hl=fr",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 10a8 8 0 0 1 7.162 3.44L24 9.5z"/></svg>`,
  },
  {
    label: "ORCID",
    value: "0009-0004-0166-1115",
    href: "https://orcid.org/0009-0004-0166-1115",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 256 256" fill="currentColor"><path d="M128 0C57.3 0 0 57.3 0 128s57.3 128 128 128 128-57.3 128-128S198.7 0 128 0zM86.3 186.2H65.1V107.5h21.2v78.7zm-10.6-90c-6.8 0-11.1-4.7-11.1-10.5 0-6 4.5-10.5 11.3-10.5 6.8 0 11 4.5 11 10.5 0 6-4.2 10.5-11.2 10.5zm100.7 90h-21.2v-44c0-10.6-.4-24.3-14.8-24.3-14.8 0-17.1 11.6-17.1 23.6v44.7H102v-78.7h20.3v10.7h.3c2.8-5.3 9.7-10.9 20-10.9 21.4 0 25.4 14.1 25.4 32.4v46.5z"/></svg>`,
