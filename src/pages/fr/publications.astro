---
import BaseLayout from '../../layouts/BaseLayout.astro';

const papers = [
  {
    title: "Automatic Recognition of Medieval Scientific Arabic Manuscripts: Dataset Creation and Large Language Models Evaluation",
    authors: ["Ismail El Jamiy", "Guillaume Loizelet", "Farah Benamara", "Nabil Hathout"],
    venue: "CORIA-TALN 2026",
    year: 2026,
    type: "Conférence",
    status: "accepted",
    doi: null,
    pdf: null,
  },
  {
    title: "Athaar: Towards Medieval Scientific Arabic Manuscript Recognition",
    authors: ["Ismail El Jamiy", "Guillaume Loizelet", "Farah Benamara", "Nabil Hathout"],
    venue: "HIP26 @ ICDAR 2026",
    year: 2026,
    type: "Atelier",
    status: "under-review",
    doi: null,
    pdf: null,
  },
  {
    title: "Few-Shot Medical Image Segmentation with Meta-Learning: An Empirical Study on Organ Segmentation",
    authors: ["Ismail El Jamiy", "Amel Aissaoui", "Lotfi Chaari"],
    venue: "2025 Medical Technologies Congress (TIPTEKNO)",
    year: 2025,
    type: "Conférence",
    status: "preprint",
    doi: null,
    pdf: null,
  },
];

const statusMeta: Record<string, { label: string; color: string }> = {
  "accepted":     { label: "Accepté",           color: "status-accepted" },
  "under-review": { label: "En évaluation",     color: "status-review" },
  "preprint":     { label: "Prépublication",    color: "status-preprint" },
};
---

<BaseLayout title="Publications" description="Publications, prépublications et posters d'Ismail El Jamiy.">
  <div class="page-container">

    <header class="page-header">
      <div class="page-eyebrow">Résultats de recherche</div>
      <h1 class="page-title">Publications</h1>
      <div class="page-rule-short" aria-hidden="true"></div>
    </header>

    <p class="intro">
      Mon doctorat a débuté en novembre 2025. Vous trouverez ci-dessous mes publications
      et soumissions en cours. Suivez mes travaux sur
      <a href="https://scholar.google.com/citations?user=QDB_Lh4AAAAJ&hl=fr" target="_blank" rel="noopener">Google Scholar</a>
      et <a href="https://orcid.org/0009-0004-0166-1115" target="_blank" rel="noopener">ORCID</a>.
    </p>

    <ol class="papers-list" reversed>
      {papers.map((paper) => {
        const meta = statusMeta[paper.status];
        return (
          <li class="paper-item card">
            <div class="paper-meta-top">
              <span class={`status-badge ${meta.color}`}>{meta.label}</span>
              <span class="paper-type">{paper.type}</span>
              <span class="paper-year">{paper.year}</span>
            </div>
            <h2 class="paper-title">{paper.title}</h2>
            <p class="paper-authors">
              {paper.authors.map((a, j) => (
                <span>
                  <span class={a === "Ismail El Jamiy" ? "author-me" : ""}>{a}</span>
                  {j < paper.authors.length - 1 ? ", " : ""}
                </span>
              ))}
            </p>
            <p class="paper-venue">{paper.venue}</p>
          </li>
        );
      })}
    </ol>

  </div>
</BaseLayout>

<style>
  .page-container { max-width: 800px; margin: 0 auto; padding: 4rem 1.5rem 5rem; }
  .page-header { margin-bottom: 1.5rem; }
  .page-title { font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 600; color: var(--fg); margin-bottom: 0.75rem; }
  .intro { font-family: var(--font-serif); font-size: 1.05rem; line-height: 1.75; color: var(--fg-muted); margin-bottom: 2.5rem; }
  .intro a { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; }
  .papers-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1.25rem; }
  .paper-item { padding: 1.5rem 1.75rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .paper-meta-top { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
  .status-badge { display: inline-block; font-family: var(--font-sans); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; padding: 0.2rem 0.65rem; border-radius: 9999px; }
  .status-accepted  { background: #d1fae5; color: #065f46; }
  .status-review    { background: #dbeafe; color: #1e40af; }
  .status-preprint  { background: #fef3c7; color: #92400e; }
  [data-theme="dark"] .status-accepted  { background: #064e3b; color: #6ee7b7; }
  [data-theme="dark"] .status-review    { background: #1e3a5f; color: #93c5fd; }
  [data-theme="dark"] .status-preprint  { background: #451a03; color: #fcd34d; }
  .paper-type, .paper-year { font-family: var(--font-sans); font-size: 0.775rem; color: var(--fg-muted); }
  .paper-type::before, .paper-year::before { content: "·"; margin-right: 0.6rem; color: var(--border); }
  .paper-title { font-family: var(--font-serif); font-size: 1.1rem; font-weight: 600; line-height: 1.45; color: var(--fg); }
  .paper-authors { font-family: var(--font-sans); font-size: 0.875rem; color: var(--fg-muted); line-height: 1.5; margin: 0; }
  .author-me { color: var(--fg); font-weight: 600; }
  .paper-venue { font-family: var(--font-sans); font-size: 0.875rem; font-style: italic; color: var(--accent); margin: 0; }
</style>
