---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="الفعاليات" description="مؤتمرات وعروض إسماعيل الجامعي.">
  <div class="page-container">
    <header class="page-header">
      <h1 class="page-title">الفعاليات</h1>
      <div class="page-rule" aria-hidden="true"></div>
    </header>
    <div class="notice">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      <p>المؤتمرات والعروض القادمة ستظهر هنا.</p>
    </div>
  </div>
</BaseLayout>
<style>
  .page-container { max-width: 800px; margin: 0 auto; padding: 4rem 1.5rem 5rem; }
  .page-header { margin-bottom: 2.5rem; }
  .page-title { font-family: var(--font-arabic); font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 700; color: var(--fg); margin-bottom: 0.75rem; }
  .page-rule { height: 2px; background: linear-gradient(to right, var(--color-olive), transparent); border-radius: 1px; }
  .notice { display: flex; gap: 1rem; align-items: center; padding: 1.25rem 1.5rem; border: 1px solid var(--border); border-radius: 0.375rem; background: var(--bg-panel); color: var(--fg-muted); font-family: var(--font-arabic); font-size: 1rem; }
  .notice svg { flex-shrink: 0; color: var(--accent); }
  .notice p { margin: 0; }
</style>
