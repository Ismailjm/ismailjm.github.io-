---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroCalligraphy from '../../components/HeroCalligraphy.astro';
---

<BaseLayout title="الرئيسية" description="إسماعيل الجامعي — طالب دكتوراه في الذكاء الاصطناعي بجامعة تولوز. بحث في التعرف على المخطوطات العلمية العربية الوسيطة.">
  <section class="hero">
    <div class="hero-inner">
      <div class="calligraphy-frame" aria-hidden="true">
        <HeroCalligraphy />
      </div>
      <div class="hero-text">
        <h1 class="hero-name">إسماعيل الجامعي</h1>
        <p class="hero-role">طالب دكتوراه في الذكاء الاصطناعي — جامعة تولوز</p>
        <p class="hero-tagline">
          التعرف الآلي على الخط المخطوط في المخطوطات العلمية العربية الوسيطة
          وبناء نماذج لغوية متخصصة.
        </p>
      </div>
      <div class="hero-ctas">
        <a href="/ar/research" class="btn-primary">استعراض البحث</a>
        <a href="/public/Resume.pdf" class="btn-secondary" target="_blank" rel="noopener">تحميل السيرة الذاتية</a>
      </div>
      <div class="scroll-hint" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             class="scroll-arrow">
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
      </div>
    </div>
  </section>

  <section class="featured">
    <div class="ornament-divider" aria-hidden="true"><span>✦</span></div>
    <div class="featured-inner">
      <a href="/ar/research" class="feature-card card fade-up">
        <div class="feature-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
        </div>
        <h2 class="feature-card-title">البحث</h2>
        <p class="feature-card-desc">التعرف الآلي على المخطوطات العربية الوسيطة بالتعلم العميق ونماذج اللغة الكبيرة.</p>
      </a>

      <a href="/ar/publications" class="feature-card card fade-up">
        <div class="feature-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
        </div>
        <h2 class="feature-card-title">المنشورات</h2>
        <p class="feature-card-desc">أوراق بحثية وملخصات من مؤتمرات وورش عمل علمية.</p>
      </a>

      <a href="/ar/projects" class="feature-card card fade-up">
        <div class="feature-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="16 18 22 12 16 6"/>
            <polyline points="8 6 2 12 8 18"/>
          </svg>
        </div>
        <h2 class="feature-card-title">المشاريع</h2>
        <p class="feature-card-desc">تطبيقات في رؤية الحاسوب ومعالجة اللغة الطبيعية والذكاء الاصطناعي.</p>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: calc(100svh - 56px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem 3rem;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    max-width: 680px;
    width: 100%;
    text-align: center;
  }

  .calligraphy-frame { width: min(380px, 80vw); opacity: 0.9; }

  .hero-name {
    font-family: var(--font-arabic);
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    font-weight: 700;
    color: var(--fg);
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .hero-role {
    font-family: var(--font-arabic);
    font-size: 1rem;
    color: var(--fg-muted);
    margin: 0 0 0.5rem;
  }

  .hero-tagline {
    font-family: var(--font-arabic);
    font-size: clamp(1rem, 2.2vw, 1.15rem);
    line-height: 1.9;
    color: var(--fg-muted);
    max-width: 540px;
    margin: 0 auto;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .btn-primary {
    font-family: var(--font-arabic);
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.65rem 1.5rem;
    background: var(--color-olive);
    color: #fff;
    border-radius: 0.375rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .btn-primary:hover { opacity: 0.87; }

  .btn-secondary {
    font-family: var(--font-arabic);
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.65rem 1.5rem;
    border: 1.5px solid var(--border);
    color: var(--fg);
    border-radius: 0.375rem;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }

  .scroll-hint { color: var(--fg-muted); opacity: 0.4; margin-top: 1rem; }
  .scroll-arrow { animation: bounce-down 2s ease-in-out infinite; }
  @keyframes bounce-down {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(5px); }
  }

  .featured {
    padding: 3rem 1.5rem 5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .featured-inner {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
    margin-top: 2rem;
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.75rem;
    text-decoration: none;
    color: var(--fg);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .feature-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px color-mix(in srgb, var(--color-olive) 12%, transparent);
  }
  .feature-card-icon { color: var(--accent); }
  .feature-card-title {
    font-family: var(--font-arabic);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--fg);
  }
  .feature-card-desc {
    font-family: var(--font-arabic);
    font-size: 0.95rem;
    color: var(--fg-muted);
    line-height: 1.8;
    margin: 0;
  }
</style>
