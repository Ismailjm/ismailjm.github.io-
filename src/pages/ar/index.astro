---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroCalligraphy from '../../components/HeroCalligraphy.astro';
---

<BaseLayout title="الرئيسية" description="اسماعيل الجامعي — طالب دكتوراه في الذكاء الاصطناعي بجامعة تولوز. بحث في التعرف على المخطوطات العلمية العربية الوسيطة.">

  <!-- ── Hero ───────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-inner">

      <!-- In RTL grid, first child lands on the right — natural Arabic start -->
      <div class="hero-calligraphy" aria-hidden="true">
        <HeroCalligraphy />
      </div>

      <div class="hero-text">
        <p class="hero-eyebrow">طالب دكتوراه في الذكاء الاصطناعي · تولوز</p>
        <h1 class="hero-name">اسماعيل<br>الجامعي</h1>
        <p class="hero-tagline">
          التعرف الآلي على الخط المخطوط في المخطوطات العلمية العربية الوسيطة
          وبناء نماذج لغوية متخصصة.
        </p>
        <div class="hero-ctas">
          <a href="/ar/research" class="btn-primary">استعراض البحث</a>
          <a href="/Resume.pdf" class="btn-secondary" target="_blank" rel="noopener">تحميل السيرة الذاتية</a>
        </div>
      </div>

    </div>

    <div class="scroll-hint" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
           class="scroll-arrow">
        <path d="M12 5v14M5 12l7 7 7-7"/>
      </svg>
    </div>
  </section>

  <!-- ── Latest publication strip ───────────────────────────────── -->
  <div class="pub-strip">
    <div class="pub-strip-inner">
      <span class="pub-strip-badge">قيد المراجعة</span>
      <span class="pub-strip-text">
        <em class="pub-strip-title">Athaar: Towards Medieval Scientific Arabic Manuscript Recognition</em>
        <span class="pub-strip-venue"> · HIP26 @ ICDAR 2026</span>
      </span>
      <a href="/ar/publications" class="pub-strip-link">← جميع المنشورات</a>
    </div>
  </div>

  <!-- ── Featured section cards ─────────────────────────────────── -->
  <section class="featured">
    <div class="ornament-divider" aria-hidden="true"><span>✦</span></div>
    <div class="featured-inner">
      <a href="/ar/research" class="feature-card card fade-up">
        <div class="feature-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
        </div>
        <h2 class="feature-card-title">البحث</h2>
        <p class="feature-card-desc">بناء مجموعات بيانات وتقييم النماذج البصرية اللغوية للتعرف على المخطوطات العلمية العربية الوسيطة.</p>
      </a>

      <a href="/ar/publications" class="feature-card card fade-up">
        <div class="feature-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
        </div>
        <h2 class="feature-card-title">المنشورات</h2>
        <p class="feature-card-desc">أوراق بحثية وملخصات من مؤتمرات وورش عمل علمية.</p>
      </a>

      <a href="/ar/projects" class="feature-card card fade-up">
        <div class="feature-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="16 18 22 12 16 6"/>
            <polyline points="8 6 2 12 8 18"/>
          </svg>
        </div>
        <h2 class="feature-card-title">المشاريع</h2>
        <p class="feature-card-desc">تطبيقات في رؤية الحاسوب ومعالجة اللغة الطبيعية والذكاء الاصطناعي.</p>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: calc(100svh - 56px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 5rem 2rem 3rem;
    background: radial-gradient(ellipse 70% 60% at 30% 40%, color-mix(in srgb, var(--color-olive) 5%, transparent), transparent);
  }

  .hero-inner {
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 5rem;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-end;
    text-align: right;
  }

  .hero-eyebrow {
    font-family: var(--font-arabic);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-terracotta);
    margin: 0;
  }

  .hero-name {
    font-family: var(--font-arabic);
    font-size: clamp(2.8rem, 5.5vw, 4.5rem);
    font-weight: 700;
    color: var(--fg);
    line-height: 1.2;
    margin: 0;
  }

  .hero-tagline {
    font-family: var(--font-arabic);
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    color: var(--fg-muted);
    line-height: 1.9;
    margin: 0;
  }

  .hero-calligraphy {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.9;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: flex-end;
  }

  .btn-primary {
    font-family: var(--font-arabic);
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.7rem 1.75rem;
    background: var(--color-olive);
    color: #fff;
    border-radius: 0.375rem;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.15s;
  }
  .btn-primary:hover { opacity: 0.87; transform: translateY(-1px); }

  .btn-secondary {
    font-family: var(--font-arabic);
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.7rem 1.75rem;
    border: 1.5px solid var(--border);
    color: var(--fg);
    border-radius: 0.375rem;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s, transform 0.15s;
  }
  .btn-secondary:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-1px); }

  .scroll-hint {
    color: var(--fg-muted);
    opacity: 0;
    margin-top: 3rem;
    animation: fade-in 0.6s ease 2.4s forwards;
  }
  .scroll-arrow { animation: bounce-down 2s ease-in-out 2.4s infinite; }
  @keyframes bounce-down {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(5px); }
  }
  @keyframes fade-in { to { opacity: 1; } }
  @media (prefers-reduced-motion: reduce) {
    .scroll-hint { animation: none; opacity: 0.4; }
    .scroll-arrow { animation: none; }
  }

  /* ── Publication strip ────────────────────────────── */
  .pub-strip {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 0.875rem 2rem;
    background: color-mix(in srgb, var(--color-olive) 3%, transparent);
  }

  .pub-strip-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    flex-direction: row-reverse;
  }

  .pub-strip-badge {
    display: inline-block;
    font-family: var(--font-arabic);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.2rem 0.65rem;
    border-radius: 9999px;
    background: #dbeafe;
    color: #1e40af;
    flex-shrink: 0;
  }

  [data-theme="dark"] .pub-strip-badge {
    background: #1e3a5f;
    color: #93c5fd;
  }

  .pub-strip-text {
    flex: 1;
    min-width: 0;
    text-align: right;
  }

  .pub-strip-title {
    font-family: var(--font-serif);
    font-size: 0.92rem;
    color: var(--fg);
  }

  .pub-strip-venue {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--fg-muted);
  }

  .pub-strip-link {
    font-family: var(--font-arabic);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    flex-shrink: 0;
    white-space: nowrap;
    transition: opacity 0.15s;
  }
  .pub-strip-link:hover { opacity: 0.7; }

  /* ── Feature cards ────────────────────────────────── */
  .featured {
    padding: 2rem 2rem 5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .featured-inner {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    margin-top: 0;
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding: 2rem;
    text-decoration: none;
    color: var(--fg);
    border-right: 3px solid var(--accent);
  }

  .feature-card-icon { color: var(--accent); }

  .feature-card-title {
    font-family: var(--font-arabic);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--fg);
  }

  .feature-card-desc {
    font-family: var(--font-arabic);
    font-size: 0.92rem;
    color: var(--fg-muted);
    line-height: 1.85;
    margin: 0;
  }

  /* ── Mobile ───────────────────────────────────────── */
  @media (max-width: 800px) {
    .hero {
      padding: 3rem 1.5rem 2rem;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero-calligraphy { order: 1; }

    .hero-text {
      order: 2;
      align-items: center;
      text-align: center;
    }

    .hero-ctas { justify-content: center; }

    .pub-strip { padding: 0.875rem 1.5rem; }
    .pub-strip-inner { flex-direction: row; }
    .pub-strip-text { text-align: start; }

    .featured { padding: 2rem 1.5rem 4rem; }
  }
</style>
