---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('publications');
const papers = entries
  .map((e) => e.data)
  .sort((a, b) => b.date.localeCompare(a.date));

function formatDate(d: string) {
  return d.split('-')[0];
}

const typeLabel: Record<string, string> = {
  journal: 'مجلة',
  conference: 'مؤتمر',
  workshop: 'ورشة عمل',
  preprint: 'نسخة أولية',
  poster: 'ملصق',
};

const statusMeta: Record<string, { label: string; color: string }> = {
  "accepted":     { label: "مقبول",        color: "status-accepted" },
  "under-review": { label: "قيد التحكيم",  color: "status-review" },
  "preprint":     { label: "نسخة أولية",   color: "status-preprint" },
  "published":    { label: "منشور",        color: "status-published" },
};
---

<BaseLayout title="المنشورات" description="المنشورات والأعمال البحثية لاسماعيل الجامعي.">
  <div class="page-container">

    <header class="page-header">
      <div class="page-eyebrow">المخرجات البحثية</div>
      <h1 class="page-title">المنشورات</h1>
      <div class="page-rule-short" aria-hidden="true"></div>
    </header>

    <p class="intro">
      بدأت الدكتوراه في نوفمبر 2025. فيما يلي منشوراتي وتقديماتي الحالية.
      تابع أعمالي على
      <a href="https://scholar.google.com/citations?user=QDB_Lh4AAAAJ&hl=ar" target="_blank" rel="noopener">Google Scholar</a>
      و<a href="https://orcid.org/0009-0004-0166-1115" target="_blank" rel="noopener">ORCID</a>.
    </p>

    <ol class="papers-list" reversed>
      {papers.map((paper) => {
        const meta = statusMeta[paper.status];
        return (
          <li class="paper-item card">
            <div class="paper-meta-top">
              <span class={`status-badge ${meta.color}`}>{meta.label}</span>
              <span class="paper-type">{typeLabel[paper.type]}</span>
              <span class="paper-year">{formatDate(paper.date)}</span>
            </div>
            <h2 class="paper-title">{paper.title}</h2>
            <p class="paper-authors">
              {paper.authors.map((a, j) => (
                <span>
                  <span class={a === "Ismail El Jamiy" ? "author-me" : ""}>{a}</span>
                  {j < paper.authors.length - 1 ? "، " : ""}
                </span>
              ))}
            </p>
            <p class="paper-venue">
              {paper.venue}
              {paper.location && <span class="paper-location"> · {paper.location}</span>}
            </p>
            {(paper.doi || paper.pdf) && (
              <div class="paper-links">
                {paper.pdf && (
                  <a href={paper.pdf} target="_blank" rel="noopener" class="paper-link">PDF</a>
                )}
                {paper.doi && (
                  <a href={`https://doi.org/${paper.doi}`} target="_blank" rel="noopener" class="paper-link">DOI</a>
                )}
              </div>
            )}
          </li>
        );
      })}
    </ol>

  </div>
</BaseLayout>

<style>
  .page-container { max-width: 800px; margin: 0 auto; padding: 4rem 1.5rem 5rem; }
  .page-header { margin-bottom: 1.5rem; }
  .page-title { font-family: var(--font-arabic); font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 700; color: var(--fg); margin-bottom: 0.75rem; }
  .intro { font-family: var(--font-arabic); font-size: 1.05rem; line-height: 1.9; color: var(--fg-muted); margin-bottom: 2.5rem; }
  .intro a { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; }
  .papers-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1.25rem; }
  .paper-item { padding: 1.5rem 1.75rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .paper-meta-top { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
  .status-badge { display: inline-block; font-family: var(--font-arabic); font-size: 0.8rem; font-weight: 700; padding: 0.2rem 0.75rem; border-radius: 9999px; }
  .status-accepted  { background: #d1fae5; color: #065f46; }
  .status-review    { background: #dbeafe; color: #1e40af; }
  .status-preprint  { background: #fef3c7; color: #92400e; }
  .status-published { background: #ede9fe; color: #5b21b6; }
  [data-theme="dark"] .status-accepted  { background: #064e3b; color: #6ee7b7; }
  [data-theme="dark"] .status-review    { background: #1e3a5f; color: #93c5fd; }
  [data-theme="dark"] .status-preprint  { background: #451a03; color: #fcd34d; }
  [data-theme="dark"] .status-published { background: #2e1065; color: #c4b5fd; }
  .paper-type, .paper-year { font-family: var(--font-arabic); font-size: 0.85rem; color: var(--fg-muted); }
  .paper-type::before, .paper-year::before { content: "·"; margin-right: 0.6rem; color: var(--border); }
  .paper-title { font-family: var(--font-sans); font-size: 1rem; font-weight: 600; line-height: 1.5; color: var(--fg); }
  .paper-authors { font-family: var(--font-sans); font-size: 0.875rem; color: var(--fg-muted); line-height: 1.5; margin: 0; }
  .author-me { color: var(--fg); font-weight: 600; }
  .paper-venue { font-family: var(--font-sans); font-size: 0.875rem; font-style: italic; color: var(--accent); margin: 0; }
  .paper-location { font-style: normal; color: var(--fg-muted); font-size: 0.82rem; }
  .paper-links { display: flex; gap: 0.75rem; margin-top: 0.25rem; }
  .paper-link { display: inline-flex; align-items: center; gap: 0.3rem; font-family: var(--font-sans); font-size: 0.775rem; font-weight: 600; color: var(--accent); text-decoration: none; border: 1px solid var(--accent); border-radius: 4px; padding: 0.2rem 0.6rem; transition: background 0.15s, color 0.15s; }
  .paper-link:hover { background: var(--accent); color: white; }
</style>
