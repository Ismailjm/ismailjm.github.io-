---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="This page could not be found.">
  <div class="notfound">
    <p class="code">404</p>
    <p class="glyph" lang="ar" aria-hidden="true">ضاع</p>
    <h1 class="title">This page wandered off</h1>
    <p class="lead">
      The page you are looking for doesn't exist or may have moved.
      Let's get you back to familiar ground.
    </p>
    <div class="actions">
      <a href="/" class="btn-primary">Return home</a>
      <a href="/research" class="btn-secondary">Read my research</a>
    </div>
  </div>
</BaseLayout>

<style>
  .notfound {
    max-width: 640px;
    margin: 0 auto;
    padding: 6rem 1.5rem 7rem;
    text-align: center;
  }

  .code {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.35em;
    color: var(--fg-muted);
    margin: 0 0 0.5rem;
  }

  .glyph {
    font-family: var(--font-arabic);
    font-size: clamp(4rem, 12vw, 7rem);
    line-height: 1;
    color: var(--color-terracotta);
    margin: 0 0 1rem;
  }

  .title {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    color: var(--fg);
    margin: 0 0 0.75rem;
  }

  .lead {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--fg-muted);
    margin: 0 auto 2rem;
    max-width: 30rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .btn-primary,
  .btn-secondary {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.6rem 1.25rem;
    border-radius: 0.375rem;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--color-ivory);
    border: 1px solid var(--accent);
  }
  .btn-primary:hover {
    background: color-mix(in srgb, var(--accent) 85%, black);
  }

  .btn-secondary {
    background: transparent;
    color: var(--accent);
    border: 1px solid var(--accent);
  }
  .btn-secondary:hover {
    background: var(--accent);
    color: var(--color-ivory);
  }
</style>
