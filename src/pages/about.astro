---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About Ismail El Jamiy — PhD candidate in AI, engineer, and photographer from Casablanca, based in Toulouse.">

  <article class="page-container">

    <header class="page-header">
      <div class="page-eyebrow">Ismail El Jamiy</div>
      <h1 class="page-title">About</h1>
      <div class="page-rule-short" aria-hidden="true"></div>
    </header>

    <div class="prose">

      <p class="drop-cap">
        I'm a PhD candidate in AI at the University of Toulouse, working at the intersection of
        computer vision and large language models. My research makes medieval Arabic manuscripts
        readable by machines, and by researchers everywhere.
      </p>

      <!-- ── Quick facts ──────────────────────────── -->
      <div class="fact-row">
        <div class="fact-chip">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>Toulouse, France</span>
        </div>
        <div class="fact-chip">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span>Moroccan, from Casablanca</span>
        </div>
        <div class="fact-chip">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
          <span>ENSAM Casablanca</span>
        </div>
      </div>

      <!-- ── Background ──────────────────────────── -->
      <h2>Background</h2>
      <p>
        I trained as an AI engineer at the École Nationale Supérieure d'Arts et Métiers
        (ENSAM Casablanca). My final year brought me to Toulouse for an internship at IRIT
        on few-shot medical image segmentation, and I never quite left. Before the PhD I also
        worked on computer vision for insurance claims at SYGMA.AI and on PPE detection at
        Lesieur Cristal.
      </p>
      <a href="/research" class="inline-link">
        See my research
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>

      <!-- ── Beyond the lab ──────────────────────── -->
      <h2>Beyond the lab</h2>
      <p>
        I photograph with my phone, drawn to moments over perfection. Light through a medina
        street, the geometry of a facade I wasn't expecting. I have a soft spot for medieval
        architecture, story-driven games and films, and music of every genre.
      </p>

      <div class="interests-grid">
        <div class="interest-chip">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
          <span>Photography</span>
        </div>
        <div class="interest-chip">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          <span>Architecture</span>
        </div>
        <div class="interest-chip">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/></svg>
          <span>Films &amp; Series</span>
        </div>
        <div class="interest-chip">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          <span>Story games</span>
        </div>
        <div class="interest-chip">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>Running</span>
        </div>
        <div class="interest-chip">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
          <span>Music</span>
        </div>
      </div>

      <!-- ── Languages ─────────────────────────────── -->
      <h2>Languages</h2>
      <div class="lang-row">
        <div class="lang-pill">
          <span class="lang-name">Arabic</span>
          <span class="lang-level">Native</span>
        </div>
        <div class="lang-pill">
          <span class="lang-name">French</span>
          <span class="lang-level">C1 · TCF 543</span>
        </div>
        <div class="lang-pill">
          <span class="lang-name">English</span>
          <span class="lang-level">Advanced</span>
        </div>
      </div>

    </div>

  </article>

</BaseLayout>

<style>
  .page-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem;
  }

  .page-header { margin-bottom: 2.5rem; }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 1rem;
  }

  /* ── Prose ──────────────────────────────────────── */
  .prose {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--fg);
  }

  .prose p { margin-bottom: 1.3em; }

  .prose h2 {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--color-olive);
    margin: 2.5rem 0 0.75rem;
  }

  .drop-cap::first-letter {
    font-size: 4.5em;
    line-height: 0.78;
    float: left;
    margin-right: 0.08em;
    color: var(--color-terracotta);
    font-weight: 600;
    font-family: var(--font-serif);
  }

  /* ── Fact chips ──────────────────────────────────── */
  .fact-row {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .fact-chip {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--fg-muted);
    background: var(--bg-panel);
    border: 1px solid var(--border);
    border-radius: 9999px;
    padding: 0.3rem 0.75rem;
  }

  .fact-chip svg { flex-shrink: 0; display: block; }

  /* ── Inline link ─────────────────────────────────── */
  .inline-link {
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
    padding-bottom: 1px;
    margin-bottom: 0.5rem;
    transition: border-color 0.15s;
  }
  .inline-link:hover { border-color: var(--accent); }
  .inline-link svg { display: block; }

  /* ── Interests ───────────────────────────────────── */
  .interests-grid {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .interest-chip {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--fg);
    background: var(--bg-panel);
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    padding: 0.4rem 0.75rem;
    transition: border-color 0.15s, transform 0.15s;
    cursor: default;
  }

  .interest-chip:hover {
    border-color: var(--color-olive);
    transform: translateY(-1px);
  }

  .interest-chip svg { display: block; flex-shrink: 0; color: var(--fg-muted); }
  .interest-chip span { white-space: nowrap; }

  /* ── Languages ───────────────────────────────────── */
  .lang-row {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .lang-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding: 0.8rem 1.5rem;
    background: var(--bg-panel);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    min-width: 110px;
    transition: border-color 0.15s, transform 0.15s;
  }

  .lang-pill:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
  }

  .lang-name {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--fg);
  }

  .lang-level {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: var(--fg-muted);
    letter-spacing: 0.02em;
  }
</style>
