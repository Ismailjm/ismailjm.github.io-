---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Eagerly import every photo so Astro can optimise (resize + WebP) at build time.
const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/photography/*.jpg',
  { eager: true },
);
const byName: Record<string, ImageMetadata> = {};
for (const path in imageModules) {
  byName[path.split('/').pop()!] = imageModules[path].default;
}

const photos = [
  { file: 'tour_eiffel_paris-fr.jpg',                      title: 'Tour Eiffel',                       place: 'Paris',        country: 'France',  lat: 48.8584, lng:  2.2945 },
  { file: 'building_toulouse-fr.jpg',                      title: 'Building',                          place: 'Toulouse',     country: 'France',  lat: 43.6047, lng:  1.4442 },
  { file: 'basilique_st_sernin_toulouse-fr.jpg',           title: 'Basilique Saint-Sernin',            place: 'Toulouse',     country: 'France',  lat: 43.6083, lng:  1.4410 },
  { file: 'chapelle_saint-joseph_toulouse-fr.jpg',         title: 'Chapelle Saint-Joseph de la Grave', place: 'Toulouse',     country: 'France',  lat: 43.5974, lng:  1.4315 },
  { file: 'musee_augusting_toulouse-fr.jpg',               title: 'Musée des Augustins',               place: 'Toulouse',     country: 'France',  lat: 43.6062, lng:  1.4454 },
  { file: 'cathedrale_notre_dame_strasbourg-fr.jpg',       title: 'Cathédrale Notre-Dame',             place: 'Strasbourg',   country: 'France',  lat: 48.5734, lng:  7.7521 },
  { file: 'building_marseille-fr.jpg',                     title: 'Building',                          place: 'Marseille',    country: 'France',  lat: 43.2965, lng:  5.3698 },
  { file: 'sculpture_marseille-fr.jpg',                    title: 'Sculpture',                         place: 'Marseille',    country: 'France',  lat: 43.2965, lng:  5.3698 },
  { file: 'beach_leucate-fr.jpg',                          title: 'Beach',                             place: 'Leucate',      country: 'France',  lat: 42.9103, lng:  3.0335 },
  { file: 'collioure-fr.jpg',                              title: 'Collioure',                         place: 'Collioure',    country: 'France',  lat: 42.5257, lng:  3.0824 },
  { file: 'building_casablanca-mar.jpg',                   title: 'Building',                          place: 'Casablanca',   country: 'Morocco', lat: 33.5731, lng: -7.5898 },
  { file: 'mosquee_hassan2_from_plane_casablanca-mar.jpg', title: 'Mosquée Hassan II',                 place: 'Casablanca',   country: 'Morocco', lat: 33.6086, lng: -7.6325 },
  { file: 'plane_casablanca-mar.jpg',                      title: 'Casablanca from the Air',           place: 'Casablanca',   country: 'Morocco', lat: 33.5731, lng: -7.5898 },
  { file: 'tower_mohammed6_rabat-morocco.jpg',             title: 'Mohammed VI Tower',                 place: 'Salé',         country: 'Morocco', lat: 34.0191, lng: -6.8051 },
  { file: 'building_stuttgaret-Germany.jpg',               title: 'Building',                          place: 'Stuttgart',    country: 'Germany', lat: 48.7758, lng:  9.1829 },
  { file: 'porche_museum_stuttgart-ger.jpg',               title: 'Porsche Museum',                    place: 'Stuttgart',    country: 'Germany', lat: 48.8340, lng:  9.1529 },
  { file: 'porche_museum2_stuttgart-ger.jpg',              title: 'Porsche Museum',                    place: 'Stuttgart',    country: 'Germany', lat: 48.8340, lng:  9.1529 },
  { file: 'tv_tower_stuttgart-ger.jpg',                    title: 'Fernsehturm Stuttgart',             place: 'Stuttgart',    country: 'Germany', lat: 48.7557, lng:  9.1902 },
];
---

<BaseLayout title="Photography" description="Photography by Ismail El Jamiy — architecture and travel across France, Morocco, and Germany.">
  <div class="page-container">

    <header class="page-header">
      <h1 class="page-title">Photography</h1>
      <div class="page-rule" aria-hidden="true"></div>
      <p class="page-subtitle">Moments captured across France, Morocco, and Germany.</p>
    </header>

    <section class="map-section" aria-label="Photo locations">
      <div id="photo-map"></div>
      <div id="filter-bar" class="filter-bar" hidden>
        <span id="filter-text"></span>
        <button id="clear-filter" type="button">Clear filter</button>
      </div>
    </section>

    <div class="masonry" id="photo-grid">
      {photos.map((p) => (
        <div class="masonry-item" data-place={p.place}>
          <div class="photo-card">
            <Image
              src={byName[p.file]}
              alt={`${p.title} — ${p.place}, ${p.country}`}
              widths={[280, 560, 840]}
              sizes="(max-width: 600px) 90vw, (max-width: 1100px) 45vw, 340px"
              loading="lazy"
              decoding="async"
            />
            <div class="photo-overlay" aria-hidden="true">
              <p class="photo-title">{p.title}</p>
              <p class="photo-place">{p.place}, {p.country}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</BaseLayout>

<script is:inline define:vars={{ photos }}>
  (function () {
    const cssLink = document.createElement('link');
    cssLink.rel = 'stylesheet';
    cssLink.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
    document.head.appendChild(cssLink);

    const script = document.createElement('script');
    script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
    script.onload = initMap;
    document.body.appendChild(script);
  })();

  function initMap() {
    const map = L.map('photo-map', { scrollWheelZoom: false }).setView([44, 2], 4);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 19,
    }).addTo(map);

    // Build location groups from photo data
    const groups = {};
    photos.forEach(function (p) {
      if (!groups[p.place]) {
        groups[p.place] = { place: p.place, country: p.country, lat: p.lat, lng: p.lng, count: 0 };
      }
      groups[p.place].count++;
    });

    const styleDefault = { radius: 9,  fillColor: '#6b7c2e', color: '#fff', weight: 2, fillOpacity: 0.85 };
    const styleActive  = { radius: 11, fillColor: '#b85c2e', color: '#fff', weight: 2, fillOpacity: 1   };
    const styleFaded   = { radius: 8,  fillColor: '#6b7c2e', color: '#fff', weight: 2, fillOpacity: 0.3  };

    let activePlace = null;
    const markers = {};

    Object.values(groups).forEach(function (loc) {
      const marker = L.circleMarker([loc.lat, loc.lng], Object.assign({}, styleDefault)).addTo(map);

      marker.bindTooltip(
        '<strong>' + loc.place + '</strong><br>' + loc.count + ' photo' + (loc.count > 1 ? 's' : ''),
        { direction: 'top', offset: L.point(0, -10) }
      );

      markers[loc.place] = marker;

      marker.on('click', function () {
        if (activePlace === loc.place) {
          clearFilter();
        } else {
          setFilter(loc.place);
        }
      });
    });

    function setFilter(place) {
      activePlace = place;

      Object.entries(markers).forEach(function (entry) {
        entry[1].setStyle(entry[0] === place ? styleActive : styleFaded);
      });

      var items = document.querySelectorAll('.masonry-item');
      var count = 0;
      items.forEach(function (item) {
        if (item.dataset.place === place) {
          item.style.display = '';
          count++;
        } else {
          item.style.display = 'none';
        }
      });

      var bar = document.getElementById('filter-bar');
      var text = document.getElementById('filter-text');
      text.textContent = count + ' photo' + (count !== 1 ? 's' : '') + ' from ' + place;
      bar.hidden = false;
    }

    function clearFilter() {
      activePlace = null;
      Object.values(markers).forEach(function (m) { m.setStyle(styleDefault); });
      document.querySelectorAll('.masonry-item').forEach(function (item) { item.style.display = ''; });
      document.getElementById('filter-bar').hidden = true;
    }

    document.getElementById('clear-filter').addEventListener('click', clearFilter);
  }
</script>

<style>
  .page-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem;
  }

  .page-header { margin-bottom: 2.5rem; }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 0.75rem;
  }

  .page-rule {
    height: 2px;
    background: linear-gradient(to right, var(--color-olive), transparent);
    border-radius: 1px;
    margin-bottom: 0.75rem;
  }

  .page-subtitle {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--fg-muted);
    margin: 0;
  }

  /* ── Map ── */
  .map-section { margin-bottom: 2.5rem; }

  #photo-map {
    height: 340px;
    border-radius: 0.5rem;
    border: 1px solid var(--border);
    overflow: hidden;
  }

  .filter-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.65rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--fg-muted);
  }
  .filter-bar[hidden] { display: none; }

  #clear-filter {
    background: none;
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    padding: 0.15rem 0.625rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--fg-muted);
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }
  #clear-filter:hover {
    border-color: var(--color-olive);
    color: var(--fg);
  }

  /* ── Masonry ── */
  .masonry {
    columns: 3 260px;
    column-gap: 0.875rem;
  }

  .masonry-item {
    break-inside: avoid;
    margin-bottom: 0.875rem;
  }

  /* ── Card ── */
  .photo-card {
    position: relative;
    overflow: hidden;
    border-radius: 0.375rem;
    background: var(--bg-panel);
    cursor: zoom-in;
  }

  .photo-card img {
    width: 100%;
    display: block;
    transition: transform 0.45s ease;
  }

  .photo-card:hover img {
    transform: scale(1.05);
  }

  .photo-overlay {
    position: absolute;
    inset: auto 0 0;
    padding: 2.5rem 0.875rem 0.875rem;
    background: linear-gradient(to top, rgba(18, 12, 4, 0.8) 0%, transparent 100%);
    transform: translateY(100%);
    transition: transform 0.32s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .photo-card:hover .photo-overlay {
    transform: translateY(0);
  }

  .photo-title {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
    color: #f5f0e8;
    margin: 0 0 0.2rem;
    line-height: 1.3;
  }

  .photo-place {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: rgba(245, 240, 232, 0.72);
    margin: 0;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
</style>
