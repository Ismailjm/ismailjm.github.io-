---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Projects" description="Engineering and research projects by Ismail El Jamiy.">
  <div class="page-container">

    <header class="page-header">
      <div class="page-eyebrow">Engineering &amp; Research</div>
      <h1 class="page-title">Projects</h1>
      <div class="page-rule-short" aria-hidden="true"></div>
    </header>

    <div class="projects-grid">
      {projects.map(project => (
        <a href={`/projects/${project.id}`} class="project-card card">
          <div class="project-card-top">
            <h2 class="project-title">{project.data.title}</h2>
            <span class="project-date">{project.data.date.slice(0, 7)}</span>
          </div>
          <p class="project-summary">{project.data.summary}</p>
          <div class="project-stack">
            {project.data.stack.slice(0, 5).map(tag => (
              <span class="stack-tag">{tag}</span>
            ))}
          </div>
          <div class="project-links" onclick="event.preventDefault()">
            {project.data.links?.github && (
              <a href={project.data.links.github} target="_blank" rel="noopener"
                 class="project-link" aria-label="GitHub">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                </svg>
                GitHub
              </a>
            )}
            <span class="project-link-read">Read more →</span>
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  .page-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem;
  }

  .page-header { margin-bottom: 2.5rem; }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 0.75rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding: 1.75rem;
    text-decoration: none;
  }

  .project-card-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.75rem;
  }

  .project-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--fg);
  }

  .project-date {
    font-family: var(--font-sans);
    font-size: 0.775rem;
    color: var(--fg-muted);
    white-space: nowrap;
  }

  .project-summary {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--fg-muted);
    line-height: 1.6;
    flex: 1;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .stack-tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.15rem 0.5rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 0.2rem;
    color: var(--fg-muted);
  }

  .project-links {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.25rem;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--fg-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .project-link:hover { color: var(--accent); }

  .project-link-read {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--accent);
    margin-left: auto;
  }
</style>
