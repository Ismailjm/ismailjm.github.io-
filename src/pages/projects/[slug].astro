---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={project.data.title} description={project.data.summary}>
  <div class="page-container">

    <nav class="breadcrumb">
      <a href="/projects">← Projects</a>
    </nav>

    <header class="project-header">
      <h1 class="project-title">{project.data.title}</h1>
      <div class="page-rule" aria-hidden="true"></div>
      <p class="project-summary">{project.data.summary}</p>

      <div class="project-meta">
        <span class="project-date">{project.data.date.slice(0, 7)}</span>
        {project.data.links?.github && (
          <a href={project.data.links.github} target="_blank" rel="noopener" class="project-link-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            View on GitHub
          </a>
        )}
      </div>

      <div class="stack-tags">
        {project.data.stack.map(tag => <span class="stack-tag">{tag}</span>)}
      </div>
    </header>

    {project.data.cover && (
      <div class="project-hero-img">
        <img src={project.data.cover} alt={project.data.title} loading="eager" />
      </div>
    )}

    <div class="prose">
      <Content />
    </div>

  </div>
</BaseLayout>

<style>
  .page-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .breadcrumb {
    margin-bottom: 2rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
  }
  .breadcrumb a { color: var(--fg-muted); text-decoration: none; transition: color 0.2s; }
  .breadcrumb a:hover { color: var(--accent); }

  .project-header { margin-bottom: 2.5rem; }

  .project-title {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 0.75rem;
  }

  .page-rule {
    height: 2px;
    background: linear-gradient(to right, var(--color-olive), transparent);
    border-radius: 1px;
    margin-bottom: 1rem;
  }

  .project-summary {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--fg-muted);
    line-height: 1.65;
    margin-bottom: 1rem;
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .project-date {
    font-family: var(--font-sans);
    font-size: 0.825rem;
    color: var(--fg-muted);
  }

  .project-link-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid var(--accent);
    padding: 0.3rem 0.875rem;
    border-radius: 0.25rem;
    transition: background 0.2s, color 0.2s;
  }
  .project-link-btn:hover { background: var(--accent); color: #fff; }

  .stack-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .stack-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    background: var(--bg-panel);
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    color: var(--fg-muted);
  }

  .project-hero-img {
    width: 100%;
    border-radius: 0.5rem;
    overflow: hidden;
    margin-bottom: 2.5rem;
    border: 1px solid var(--border);
  }

  .project-hero-img img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Prose ────────────────────────────────────────────────── */
  .prose {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--fg);
  }
  .prose :global(p) { margin-bottom: 1.3em; }
  .prose :global(h2) {
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--color-olive);
    margin: 2.25rem 0 0.75rem;
    font-family: var(--font-serif);
  }
  .prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--fg);
    margin: 1.5rem 0 0.5rem;
  }
  .prose :global(ul) { list-style: none; padding: 0; margin-bottom: 1.3em; }
  .prose :global(ul li) {
    padding-left: 1.25rem;
    position: relative;
    margin-bottom: 0.5em;
  }
  .prose :global(ul li)::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--color-terracotta);
  }
  .prose :global(strong) { font-weight: 600; color: var(--fg); }
</style>
