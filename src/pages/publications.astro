---
import BaseLayout from '../layouts/BaseLayout.astro';

const papers = [
  {
    title: "Athaar: Towards Medieval Scientific Arabic Manuscript Recognition",
    authors: ["Ismail El Jamiy", "Guillaume Loizelet", "Farah Benamara", "Nabil Hathout"],
    venue: "HIP26 @ ICDAR 2026",
    location: "Vienna, Austria",
    date: "Sep. 2026",
    type: "Workshop",
    status: "under-review",
    doi: null,
    pdf: null,
  },
  {
    title: "Automatic Recognition of Medieval Scientific Arabic Manuscripts: Dataset Creation and Large Language Models Evaluation",
    authors: ["Ismail El Jamiy", "Guillaume Loizelet", "Farah Benamara", "Nabil Hathout"],
    venue: "CORIA-TALN 2026",
    location: "Nantes, France",
    date: "Jun. 2026",
    type: "Conference",
    status: "accepted",
    doi: null,
    pdf: null,
  },
  {
    title: "Few-Shot Medical Image Segmentation with Meta-Learning: An Empirical Study on Organ Segmentation",
    authors: ["Ismail El Jamiy", "Amel Aissaoui", "Lotfi Chaari"],
    venue: "Medical Technologies Congress (TIPTEKNO 2025)",
    location: "Gazimağusa, Turkey",
    date: "Oct. 2025",
    type: "Conference",
    status: "published",
    doi: "10.1109/TIPTEKNO68206.2025.11270127",
    pdf: null,
  },
];

const statusMeta: Record<string, { label: string; color: string }> = {
  "accepted":     { label: "Accepted",     color: "status-accepted" },
  "under-review": { label: "Under Review", color: "status-review" },
  "preprint":     { label: "Preprint",     color: "status-preprint" },
  "published":    { label: "Published",    color: "status-published" },
};
---

<BaseLayout title="Publications" description="Publications, preprints, and posters by Ismail El Jamiy.">
  <div class="page-container">

    <header class="page-header">
      <div class="page-eyebrow">Research output</div>
      <h1 class="page-title">Publications</h1>
      <div class="page-rule-short" aria-hidden="true"></div>
    </header>

    <p class="intro">
      My PhD began in November 2025. Below are my current publications and submissions.
      Follow my work on
      <a href="https://scholar.google.com/citations?user=QDB_Lh4AAAAJ&hl=en" target="_blank" rel="noopener">Google Scholar</a>
      and <a href="https://orcid.org/0009-0004-0166-1115" target="_blank" rel="noopener">ORCID</a>.
    </p>

    <ol class="papers-list" reversed>
      {papers.map((paper, i) => {
        const meta = statusMeta[paper.status];
        return (
          <li class="paper-item card">
            <div class="paper-meta-top">
              <span class={`status-badge ${meta.color}`}>{meta.label}</span>
              <span class="paper-type">{paper.type}</span>
              <span class="paper-year">{paper.date}</span>
            </div>

            <h2 class="paper-title">{paper.title}</h2>

            <p class="paper-authors">
              {paper.authors.map((a, j) => (
                <span>
                  <span class={a === "Ismail El Jamiy" ? "author-me" : ""}>{a}</span>
                  {j < paper.authors.length - 1 ? ", " : ""}
                </span>
              ))}
            </p>

            <p class="paper-venue">
              {paper.venue}
              {paper.location && <span class="paper-location"> · {paper.location}</span>}
            </p>

            {(paper.doi || paper.pdf) && (
              <div class="paper-links">
                {paper.pdf && (
                  <a href={paper.pdf} target="_blank" rel="noopener" class="paper-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                      <polyline points="14 2 14 8 20 8"/>
                    </svg>
                    PDF
                  </a>
                )}
                {paper.doi && (
                  <a href={`https://doi.org/${paper.doi}`} target="_blank" rel="noopener" class="paper-link">
                    DOI
                  </a>
                )}
              </div>
            )}
          </li>
        );
      })}
    </ol>

  </div>
</BaseLayout>

<style>
  .page-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem;
  }

  .page-header { margin-bottom: 1.5rem; }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 0.75rem;
  }

  .intro {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--fg-muted);
    margin-bottom: 2.5rem;
  }

  .intro a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .papers-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    counter-reset: paper-counter;
  }

  .paper-item {
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .paper-meta-top {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .status-badge {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 0.2rem 0.65rem;
    border-radius: 9999px;
  }

  .status-accepted  { background: #d1fae5; color: #065f46; }
  .status-review    { background: #dbeafe; color: #1e40af; }
  .status-preprint  { background: #fef3c7; color: #92400e; }
  .status-published { background: #ede9fe; color: #5b21b6; }

  [data-theme="dark"] .status-accepted  { background: #064e3b; color: #6ee7b7; }
  [data-theme="dark"] .status-review    { background: #1e3a5f; color: #93c5fd; }
  [data-theme="dark"] .status-preprint  { background: #451a03; color: #fcd34d; }
  [data-theme="dark"] .status-published { background: #2e1065; color: #c4b5fd; }

  .paper-type, .paper-year {
    font-family: var(--font-sans);
    font-size: 0.775rem;
    color: var(--fg-muted);
  }

  .paper-type::before {
    content: "·";
    margin-right: 0.6rem;
    color: var(--border);
  }

  .paper-year::before {
    content: "·";
    margin-right: 0.6rem;
    color: var(--border);
  }

  .paper-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.45;
    color: var(--fg);
  }

  .paper-authors {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--fg-muted);
    line-height: 1.5;
    margin: 0;
  }

  .author-me {
    color: var(--fg);
    font-weight: 600;
  }

  .paper-venue {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-style: italic;
    color: var(--accent);
    margin: 0;
  }

  .paper-location {
    font-style: normal;
    color: var(--fg-muted);
    font-size: 0.82rem;
  }

  .paper-links {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .paper-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-sans);
    font-size: 0.775rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid var(--accent);
    border-radius: 4px;
    padding: 0.2rem 0.6rem;
    transition: background 0.15s, color 0.15s;
  }

  .paper-link:hover {
    background: var(--accent);
    color: white;
  }
</style>
