---
// No server-side props needed — purely client-driven
---

<div class="flex items-center gap-0.5" role="group" aria-label="Reading mode">
  <button data-theme-btn="light"  title="Light"     class="theme-btn" aria-pressed="false">
    <!-- Sun -->
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="4"/>
      <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
    </svg>
  </button>
  <button data-theme-btn="parchment" title="Parchment" class="theme-btn" aria-pressed="false">
    <!-- Scroll -->
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
      <polyline points="14 2 14 8 20 8"/>
      <line x1="8" y1="13" x2="16" y2="13"/>
      <line x1="8" y1="17" x2="16" y2="17"/>
    </svg>
  </button>
  <button data-theme-btn="dark"   title="Dark"      class="theme-btn" aria-pressed="false">
    <!-- Moon -->
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/>
    </svg>
  </button>
</div>

<style is:global>
  .theme-btn {
    padding: 0.25rem;
    border-radius: 0.25rem;
    color: var(--fg);
    opacity: 0.45;
    transition: opacity 0.2s, color 0.2s;
    cursor: pointer;
    background: transparent;
    border: none;
    display: flex;
    align-items: center;
  }
  .theme-btn:hover,
  .theme-btn[aria-pressed="true"] {
    opacity: 1;
    color: var(--accent);
  }
  [data-theme="dark"] .theme-btn:hover,
  [data-theme="dark"] .theme-btn[aria-pressed="true"] {
    color: var(--color-gold);
  }
</style>

<script>
  const root = document.documentElement;
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-theme-btn]');

  function applyTheme(theme: string) {
    root.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
    buttons.forEach(btn => {
      btn.setAttribute('aria-pressed', btn.dataset.themeBtn === theme ? 'true' : 'false');
    });
  }

  // Sync on load
  const saved = localStorage.getItem('theme') ?? 'light';
  applyTheme(saved);

  buttons.forEach(btn => {
    btn.addEventListener('click', () => applyTheme(btn.dataset.themeBtn!));
  });
</script>
